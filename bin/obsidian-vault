#!/bin/bash
# obsidian-vault — CLI for encrypted Obsidian LiveSync vault
# Runs via tsx (TypeScript ESM) with custom path-alias loader

# Resolve through symlinks so this works when called via ~/.local/bin or /usr/local/bin
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
CLI_DIR="$(dirname "$SCRIPT_DIR")"

# NODE_ENV=development enables oclif to discover TypeScript commands at runtime
# without needing a pre-generated .oclif.manifest.json
export NODE_ENV="${NODE_ENV:-development}"

TSX_ESM="$CLI_DIR/node_modules/tsx/dist/esm/index.cjs"

exec node \
  --import "$TSX_ESM" \
  --experimental-loader "$CLI_DIR/path-loader.mjs" \
  --no-warnings \
  "$CLI_DIR/src/index.ts" \
  "$@"
