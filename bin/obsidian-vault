#!/bin/bash
# obsidian-vault — CLI for encrypted Obsidian LiveSync vault

# Resolve through symlinks so this works when called via ~/.local/bin
SOURCE="$0"
while [ -L "$SOURCE" ]; do
  DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
CLI_DIR="$(dirname "$SCRIPT_DIR")"

exec node --no-warnings "$CLI_DIR/dist/index.cjs" "$@"
