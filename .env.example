# Copy this file to ~/.config/obsidian-vault/config
# (XDG_CONFIG_HOME is respected if set)
#
# Environment variables take highest priority and override this file.

# CouchDB credentials
COUCHDB_USER=your_admin_user
COUCHDB_PASSWORD=your_secure_password

# Obsidian LiveSync end-to-end encryption passphrase
# This is the passphrase you configured in the LiveSync plugin settings.
# It is NEVER stored in CouchDB — you must provide it here.
E2EE_PASSPHRASE=your_e2ee_passphrase

# CouchDB database name (default: obsidiannotes)
DB_NAME=obsidiannotes

# CouchDB URL (default: http://127.0.0.1:5984)
# COUCHDB_URL=http://127.0.0.1:5984
